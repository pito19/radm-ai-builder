# Générer une clé (une seule fois, hors script)
gpg --batch --passphrase 'VOTRE_PASSPHRASE_SECURISEE' --quick-gen-key "RADM OIV Build Key" default default 0
gpg --armor --export-secret-key "RADM OIV Build Key" > radm-build-key.asc
# ⚠️ Ce fichier .asc doit être stocké SÉCURISEMENT (hors Git, dans Vault)